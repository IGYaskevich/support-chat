PORT=8080
PUBLIC_BASE_URL=https://your-public-domain.example.com

OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
FAQ_VECTOR_STORE_ID=

# Optional issue tracker endpoint for register_issue tool
ISSUE_TRACKER_URL=
ISSUE_TRACKER_TOKEN=

# Twilio WhatsApp inbound webhook signature validation
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=true

# Optional: skip signature validation only for local smoke tests
# TWILIO_VALIDATE_SIGNATURE=false

# Persistent state
STATE_FILE=./data/state.json

# OpenAI tool-loop safety
MAX_TOOL_ITERATIONS=3
